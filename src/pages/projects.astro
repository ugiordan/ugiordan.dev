---
import Layout from '../layouts/Page.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects')).sort(
	(a, b) => a.data.order - b.data.order,
);

const categories = ['Security & Platform', 'AI Tooling', 'Developer Tools', 'Pipeline Validation'] as const;
const grouped = categories.map((cat) => ({
	category: cat,
	projects: allProjects.filter((p) => p.data.category === cat),
})).filter((g) => g.projects.length > 0);
---

<Layout title="Projects" description="Projects by Ugo Giordano">
	{grouped.map((group, i) => (
		<section>
			<h2 class:list={['text-text-muted font-normal uppercase tracking-widest text-xs mb-5', i === 0 ? 'mt-0' : 'mt-10']}>{group.category}</h2>
			<div class="grid grid-cols-2 gap-3 max-sm:grid-cols-1">
				{group.projects.map((project) => (
					<ProjectCard
						title={project.data.title}
						description={project.data.description}
						tags={project.data.tags}
						links={project.data.links}
						visibility={project.data.visibility}
					/>
				))}
			</div>
		</section>
	))}
</Layout>
