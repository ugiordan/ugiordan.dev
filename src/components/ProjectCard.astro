---
interface Props {
	title: string;
	description: string;
	tags: string[];
	links: { label: string; url: string }[];
	visibility: 'public' | 'private';
}

const { title, description, tags, links, visibility } = Astro.props;
---

<div class="bg-bg-secondary border border-border rounded-lg p-5 transition-colors duration-150 hover:border-border-hover">
	<div class="flex gap-2 mb-3 flex-wrap">
		{tags.map((tag) => (
			<span class="py-0.5 px-2 rounded text-xs bg-code-bg text-accent">{tag}</span>
		))}
	</div>
	<h4 class="text-text text-[0.95em] mb-1.5">{title}</h4>
	<p class="text-text-secondary text-sm leading-normal m-0">{description}</p>
	<div class="mt-3 flex gap-3">
		{links.length > 0 ? (
			links.map((link) => (
				<a href={link.url} target={link.url.startsWith('/') ? undefined : '_blank'} rel={link.url.startsWith('/') ? undefined : 'noopener noreferrer'}
					class="text-accent text-xs no-underline hover:text-accent-hover hover:underline">
					{link.label} &rarr;
				</a>
			))
		) : visibility === 'private' ? (
			<span class="text-text-muted text-xs">Private repo</span>
		) : null}
	</div>
</div>
